"""
📄 Homework Document Generator
Creates formatted .docx files from Claude's responses
"""

from docx import Document
from docx.shared import Pt, RGBColor, Inches
from docx.enum.text import WD_ALIGN_PARAGRAPH
import datetime
import os
import re


def create_homework_doc(topic: str, content: str) -> str:
    """
    Generate a formatted academic Word document.
    Returns the file path of the saved document.
    """
    doc = Document()

    # ── Page margins ─────────────────────────────
    for section in doc.sections:
        section.top_margin    = Inches(1)
        section.bottom_margin = Inches(1)
        section.left_margin   = Inches(1.25)
        section.right_margin  = Inches(1.25)

    # ── Title ────────────────────────────────────
    title = doc.add_heading(topic.title(), level=0)
    title.alignment = WD_ALIGN_PARAGRAPH.CENTER
    title.runs[0].font.color.rgb = RGBColor(0x1A, 0x1A, 0x2E)

    # ── Meta info ────────────────────────────────
    date_str = datetime.datetime.now().strftime("%B %d, %Y")
    meta = doc.add_paragraph(f"Generated: {date_str} | AI Academic Assistant")
    meta.alignment = WD_ALIGN_PARAGRAPH.CENTER
    meta.runs[0].font.size = Pt(9)
    meta.runs[0].font.color.rgb = RGBColor(0x88, 0x88, 0x88)

    doc.add_paragraph()  # spacer

    # ── Parse and write content ───────────────────
    lines = content.split("\n")
    in_references = False

    for line in lines:
        line = line.strip()
        if not line:
            doc.add_paragraph()
            continue

        # Detect APA References section
        if re.match(r"^references$", line, re.IGNORECASE):
            in_references = True
            h = doc.add_heading("References", level=1)
            h.runs[0].font.color.rgb = RGBColor(0x1A, 0x1A, 0x2E)
            continue

        # Markdown-style headings
        if line.startswith("## "):
            h = doc.add_heading(line[3:], level=2)
            h.runs[0].font.color.rgb = RGBColor(0x16, 0x37, 0x7C)
            continue

        if line.startswith("# "):
            h = doc.add_heading(line[2:], level=1)
            h.runs[0].font.color.rgb = RGBColor(0x1A, 0x1A, 0x2E)
            continue

        # Bullet points
        if line.startswith("- ") or line.startswith("* "):
            p = doc.add_paragraph(line[2:], style="List Bullet")
            p.runs[0].font.size = Pt(11)
            continue

        # Numbered list
        if re.match(r"^\d+\. ", line):
            text = re.sub(r"^\d+\. ", "", line)
            p = doc.add_paragraph(text, style="List Number")
            p.runs[0].font.size = Pt(11)
            continue

        # APA reference lines (hanging indent style)
        if in_references and line:
            p = doc.add_paragraph()
            p.paragraph_format.left_indent  = Inches(0.5)
            p.paragraph_format.first_line_indent = Inches(-0.5)
            run = p.add_run(line)
            run.font.size = Pt(11)
            continue

        # Bold text (**text**)
        if "**" in line:
            p = doc.add_paragraph()
            parts = line.split("**")
            for i, part in enumerate(parts):
                run = p.add_run(part)
                run.bold = (i % 2 == 1)
                run.font.size = Pt(11)
            p.paragraph_format.space_after = Pt(6)
            continue

        # Regular paragraph
        p = doc.add_paragraph(line)
        p.runs[0].font.size = Pt(11)
        p.paragraph_format.space_after = Pt(6)
        p.paragraph_format.line_spacing = Pt(22)  # ~1.5 spacing

    # ── Footer ───────────────────────────────────
    footer = doc.sections[0].footer
    footer_para = footer.paragraphs[0]
    footer_para.text = "Generated by AI Academic Assistant | For review purposes"
    footer_para.alignment = WD_ALIGN_PARAGRAPH.CENTER
    footer_para.runs[0].font.size = Pt(8)
    footer_para.runs[0].font.color.rgb = RGBColor(0xAA, 0xAA, 0xAA)

    # ── Save ─────────────────────────────────────
    os.makedirs("generated_docs", exist_ok=True)
    safe_name = re.sub(r"[^\w\s-]", "", topic)[:40].strip().replace(" ", "_")
    timestamp  = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    filepath   = f"generated_docs/{safe_name}_{timestamp}.docx"

    doc.save(filepath)
    print(f"✅ Document saved: {filepath}")
    return filepath


